  "dependencies": {
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/pg": "^8.13.1",
    "@types/uuid": "^11.0.0",
    "bun-types": "latest",
    "pg": "^8.14.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "pg": "^8.14.1"
  }
